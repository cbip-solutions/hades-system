<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zenswarm.ctld</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{CTLD_PATH}}</string>
        <string>-uds</string>
        <string>/tmp/zen-swarm.sock</string>
        <string>-http</string>
        <string>127.0.0.1:8080</string>
        <string>-db</string>
        <string>{{HOME}}/.local/share/zen-swarm/state.db</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>StandardOutPath</key>
    <string>{{HOME}}/.local/share/zen-swarm/logs/ctld.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>{{HOME}}/.local/share/zen-swarm/logs/ctld.stderr.log</string>

    <key>WorkingDirectory</key>
    <string>{{HOME}}/.local/share/zen-swarm</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
