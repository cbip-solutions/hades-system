[project]
name = "{{.ProjectName}}"
version = "0.1.0"
description = "{{.ProjectName}} CLI"
requires-python = ">=3.11"
dependencies = ["click>=8.1"]

[project.scripts]
{{.ProjectName}} = "{{.ProjectName}}.cli:main"

[build-system]
requires = ["setuptools>=68"]
build-backend = "setuptools.build_meta"
