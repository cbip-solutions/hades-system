<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.zen-swarm.docs-cron</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{CRON_BIN_PATH}}</string>
        <string>-daemon-uds</string>
        <string>/tmp/zen-swarm.sock</string>
        <string>-timezone</string>
        <string>{{TIMEZONE}}</string>
        <string>-poll-interval</string>
        <string>6h</string>
        <string>-sweep-hour</string>
        <string>3</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>{{HOME}}/.local/share/zen-swarm/logs/docs-cron.out</string>

    <key>StandardErrorPath</key>
    <string>{{HOME}}/.local/share/zen-swarm/logs/docs-cron.err</string>

    <key>WorkingDirectory</key>
    <string>{{HOME}}/.local/share/zen-swarm</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>
</dict>
</plist>
