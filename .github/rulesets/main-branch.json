{
  "name": "main-branch-release-gates",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "~DEFAULT_BRANCH"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion"
    },
    {
      "type": "non_fast_forward"
    },
    {
      "type": "required_signatures"
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": true,
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          { "context": "verify-brew-formula",             "integration_id": 15368 },
          { "context": "verify-hermes",                   "integration_id": 15368 },
          { "context": "smoke-hermes-plugin",             "integration_id": 15368 },
          { "context": "smoke-hermes-plugin-real",        "integration_id": 15368 },
          { "context": "verify-spikes-rerun",             "integration_id": 15368 },
          { "context": "verify-30-ci-green",              "integration_id": 15368 },
          { "context": "verify-license-disclosure",       "integration_id": 15368 },
          { "context": "verify-bypass-sidecar",           "integration_id": 15368 },
          { "context": "verify-no-bypass-references",     "integration_id": 15368 },
          { "context": "verify-sidecar-capability-negotiation", "integration_id": 15368 },
          { "context": "verify-license-compliance",       "integration_id": 15368 },
          { "context": "verify-multi-arch",               "integration_id": 15368 },
          { "context": "verify-signatures",               "integration_id": 15368 },
          { "context": "verify-release-artifacts",        "integration_id": 15368 },
          { "context": "verify-cgo-supplement",           "integration_id": 15368 },
          { "context": "verify-chaos-suite",              "integration_id": 15368 },
          { "context": "verify-docs-maturity",            "integration_id": 15368 },
          { "context": "verify-cross-workflow-freshness", "integration_id": 15368 },
          { "context": "verify-invariants",               "integration_id": 15368 },
          { "context": "test-tiers",                      "integration_id": 15368 },
          { "context": "verify-changelog-completeness",   "integration_id": 15368 },
          { "context": "verify-dco-signoff",              "integration_id": 15368 },
          { "context": "verify-canonical-docs-hygiene",   "integration_id": 15368 },
          { "context": "verify-no-personal-references",   "integration_id": 15368 },
          { "context": "verify-no-task-context-comments", "integration_id": 15368 },
          { "context": "verify-godoc-clean",              "integration_id": 15368 },
          { "context": "verify-hermes-boundary",          "integration_id": 15368 }
        ]
      }
    }
  ],
  "bypass_actors": [
    {
      "actor_id": 5,
      "actor_type": "RepositoryRole",
      "bypass_mode": "always"
    }
  ]
}
